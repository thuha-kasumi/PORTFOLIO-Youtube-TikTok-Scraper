# Core
YOUTUBE_API_KEY = "your_youtube_api_key"
DATABASE_URL = "postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"
DB_SCHEMA = "social_scraper"

# Reddit, required only when platform = Reddit
REDDIT_CLIENT_ID = "your_reddit_client_id"
REDDIT_CLIENT_SECRET = "your_reddit_client_secret"
REDDIT_USER_AGENT = "social-content-scraper/1.0 by your_reddit_username"

# Meta Graph API, required only when platform = Facebook or Instagram
META_ACCESS_TOKEN = "your_meta_graph_api_token"
