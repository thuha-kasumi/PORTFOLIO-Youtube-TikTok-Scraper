# .streamlit/secrets.toml
# DO NOT COMMIT your real secrets file.
# Copy this example to .streamlit/secrets.toml and replace the placeholders.

# YouTube Data API v3 key
YOUTUBE_API_KEY = "YOUR_YOUTUBE_DATA_API_V3_KEY"

# Neon/PostgreSQL connection string
# Use the pooled Neon connection string when deploying on Streamlit Cloud.
# Format:
# postgresql+psycopg2://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL = "postgresql+psycopg2://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Optional local fallback only, if your app supports SQLite fallback.
# SQLITE_PATH = "social_scraper_local.db"
